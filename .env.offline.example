# =============================================================================
# Diamond KMS - Konfigurasi Offline / On-Premise (LAN)
# =============================================================================
# Copy file ini menjadi .env sebelum menjalankan docker compose
#
#   cp .env.offline.example .env
#   docker compose -f docker-compose.offline.yml up -d
# =============================================================================

# --- PostgreSQL Database ---
POSTGRES_DB=diamondkms
POSTGRES_USER=diamondkms
POSTGRES_PASSWORD=DiamondKMS2026!
DB_PORT=5432

# --- Diamond KMS App ---
APP_PORT=7000

# --- AI (Ollama Lokal) ---
OLLAMA_PORT=11434
AI_CHAT_MODEL=gemma3:4b
AI_EMBED_MODEL=nomic-embed-text
AI_RERANK_MODEL=
AI_VISION_EMBED_MODEL=
AI_TEMPERATURE=0.7
AI_SIMILARITY_THRESHOLD=0.40
AI_TOP_P=0.9
AI_TOP_K=40
AI_REPETITION_PENALTY=1.15
AI_MAX_TOKENS=2048
AI_EMBEDDING_DIMENSIONS=768

# --- Security ---
NEXTAUTH_SECRET=ganti-dengan-string-random-yang-panjang
CRON_SECRET=diamond-kms-cron-secret
ENCRYPTION_KEY=diamond-kms-encryption-key-32chr

# --- Instance Identity ---
INSTANCE_KEY=DKMS-OFFLINE-001
INSTANCE_NAME=Diamond KMS - PT Nama Perusahaan

# --- License ---
ACTIVATION_MODE=offline
LICENSE_SECRET=diamond-kms-shared-secret-2026
LICENSE_KEY=
