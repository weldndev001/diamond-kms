# =============================================================================
# Diamond KMS - Konfigurasi Online (Cloud / Vercel / VPS)
# =============================================================================
# Copy file ini menjadi .env dan sesuaikan nilainya.
#
# Untuk Vercel:
#   Set semua variabel di Settings > Environment Variables
#
# Untuk VPS/Docker:
#   cp .env.online.example .env
#   nano .env
# =============================================================================

# --- Storage ---
UPLOAD_DIR="./uploads"

# --- Database (Cloud PostgreSQL) ---
# Gunakan connection string dari provider database Anda
# Contoh: Supabase, Neon, AWS RDS, atau self-hosted
DATABASE_URL="postgresql://user:password@host:5432/diamondkms"
DIRECT_URL="postgresql://user:password@host:5432/diamondkms"

# --- AI Provider ---
# Pilih salah satu opsi di bawah:

# Opsi 1: Google Gemini (Managed)
AI_PROVIDER="managed"
GEMINI_API_KEY="AIzaSy..."
# AI_CHAT_MODEL="gemini-2.5-flash"

# Opsi 2: Self-hosted (Olla / Ollama di server terpisah)
# AI_PROVIDER="self_hosted"
# AI_ENDPOINT="https://ai-server-anda.com/v1"
# AI_API_KEY="api-key-anda"
# AI_CHAT_MODEL="gemma-4-E2B-it-Q4_K_M-unsloth.gguf"
# AI_EMBED_MODEL="qwen3-vl-embedding-2b-q4_k_m-devquasar.gguf"
# AI_RERANK_MODEL="qwen3-reranker-0.6b-q8_0-ggmlorg.gguf"
# AI_VISION_EMBED_MODEL="qwen3-vl-embedding-2b-q4_k_m-devquasar.gguf"

# AI Parameters
AI_HYBRID_VISION="false"
AI_HYBRID_EMBED="false"
AI_TEMPERATURE="0.7"
AI_SIMILARITY_THRESHOLD="0.40"
AI_TOP_P="0.9"
AI_TOP_K="40"
AI_REPETITION_PENALTY="1.15"
AI_MAX_TOKENS="2048"
AI_EMBEDDING_DIMENSIONS="768"

# --- Security ---
NEXTAUTH_URL="https://domain-anda.com"
NEXTAUTH_SECRET="ganti-dengan-string-random-yang-sangat-panjang"
NEXT_PUBLIC_APP_URL="https://domain-anda.com"
CRON_SECRET="ganti-dengan-string-random"
ENCRYPTION_KEY="tepat-32-karakter-untuk-encrypt"

# --- Monitoring Center Integration ---
INSTANCE_KEY="DKMS-PROD-001"
INSTANCE_NAME="Diamond KMS - Nama Perusahaan"
MONITORING_CENTER_URL=""

# --- License ---
ACTIVATION_MODE="online"
LICENSE_SECRET="diamond-kms-shared-secret-2026"
LICENSE_KEY=""
